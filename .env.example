# Template — COPY sang .env.local rồi điền giá trị thật. File này AN TOÀN để commit.

# ===== Supabase (server) =====
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxx          # service key — SERVER ONLY
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# ===== LLM — Gemini via Vercel AI Gateway =====
AI_GATEWAY_API_KEY=vck_xxx
GIL_MODEL=google/gemini-2.5-flash

# ===== Walrus / MemWal =====
MEMWAL_ACCOUNT_ID=
MEMWAL_DELEGATE_KEY=
MEMWAL_RELAYER_URL=https://relayer.memory.walrus.xyz
SESSION_WALLET_KEY=suiprivkey...
SUI_NETWORK=mainnet
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
SUI_EXPLORER_OBJECT_URL_TEMPLATE=https://suiscan.xyz/{network}/object/{id}
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-mainnet.walrus.space
WALRUS_PUBLISHER_URL=                 # optional: private publisher base URL, e.g. https://publisher.example.com
WALRUS_PUBLISHER_TOKEN=               # optional bearer token for authenticated publisher
WALRUS_SDK_WALLET_KEY=                # optional: defaults to SESSION_WALLET_KEY for direct TypeScript SDK blob writes
WALRUS_SDK_DISABLED=false
WALRUS_CLI_DISABLED=false             # set true to disable local Walrus CLI fallback
WALRUS_BLOB_EPOCHS=12
# Upload relay offloads slow storage coordination so SDK writes finish within serverless time limits (e.g. Vercel 60s).
# Defaults to Mysten's public relay for the active network; signer still pays WAL + a small SUI tip.
WALRUS_UPLOAD_RELAY_DISABLED=false     # set true to write blobs without the relay (direct, slower)
WALRUS_UPLOAD_RELAY_HOST=              # optional override, defaults to upload-relay.<network>.walrus.space
WALRUS_UPLOAD_RELAY_TIP_MAX=10000000   # max tip in MIST the signer will pay the relay per blob (~2.6M needed for a briefing)
WALRUS_SITE_CONTEXT=mainnet
WALRUS_SITE_EPOCHS=12
SITE_BUILDER_BIN=site-builder
WALRUS_BINARY=walrus
CORS_ORIGINS=https://<suins>.wal.app,http://localhost:5173
BRIEFING_PUBLISHER_WALLET_KEY=       # optional: signs Sui OutputRecord receipts for daily briefings
BRIEFING_SOURCE_URLS=                # optional comma-separated allowlist of public sources to scout
BRIEFING_SIDE_STORIES_JSON=          # optional JSON array: [{"title":"...","url":"...","facts":["..."]}]
BRIEFING_SOURCE_TIMEOUT_MS=3500
BRIEFING_POST_SCORE_ENABLED=false

# ===== WC2026 / Oracle / Admin =====
ORACLE_ADMIN_TOKEN=change-me
WC_INDEXER_INTERVAL_MS=15000
WC_INDEXER_DISABLED=0
WC_PACKAGE_ID=
WC_REGISTRY_ID=
WC_SCOREBOARD_ID=
WC_ADMIN_CAP_ID=
WC_ORACLE_CAP_ID=

# ===== Frontend (Vite) — PUBLIC =====
VITE_MASTRA_URL=http://localhost:4111
VITE_SUPABASE_URL=https://<ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
VITE_SUI_NETWORK=mainnet
