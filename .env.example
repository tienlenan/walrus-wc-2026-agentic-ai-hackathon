# Template cấu hình — COPY sang .env.local rồi điền giá trị thật.
# File .example này AN TOÀN để commit (chỉ placeholder).

# ========== Mastra server (Railway) — SECRET, chỉ ở server ==========
ANTHROPIC_API_KEY=
# Supabase Postgres (Settings → Database → Connection string → "Session pooler", port 5432)
DATABASE_URL=postgresql://postgres.<ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxx          # service key — SERVER ONLY, không bao giờ ở frontend

# Walrus Memory (MemWal)
MEMWAL_ACCOUNT_ID=
MEMWAL_DELEGATE_KEY=
MEMWAL_RELAYER_URL=https://relayer.memory.walrus.xyz

# Sui / Walrus
SESSION_WALLET_KEY=suiprivkey...           # dedicated session wallet (nạp WAL + SUI)
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-mainnet.walrus.space
CORS_ORIGINS=https://<suins>.wal.app,http://localhost:5173

# ========== Frontend (Vite) — PUBLIC, an toàn để lộ ==========
VITE_MASTRA_URL=http://localhost:4111
VITE_SUPABASE_URL=https://<ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx   # publishable/anon — KHÔNG phải secret
VITE_SUI_NETWORK=mainnet
VITE_WALRUS_AGGREGATOR_URL=https://aggregator.walrus-mainnet.walrus.space
VITE_SUINS_NAME=
