{
  "name": "daily-walrus",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "The Daily Walrus — AI World Cup 2026 pundit with persistent memory on Walrus. Walrus Memory World Cup hackathon.",
  "license": "MIT",
  "engines": {
    "node": ">=20.9.0"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @daily-walrus/web dev",
    "dev:web:test": "pnpm --filter @daily-walrus/web dev:test",
    "dev:server": "pnpm --filter @daily-walrus/server dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @daily-walrus/web build",
    "typecheck": "pnpm -r typecheck",
    "deploy:walrus-site": "./scripts/deploy-walrus-site.sh",
    "keep-alive": "apps/server/node_modules/.bin/tsx scripts/keep-alive.ts",
    "register:fixtures": "pnpm --filter @daily-walrus/server register:fixtures",
    "score:match": "pnpm --filter @daily-walrus/server score:match",
    "capture:screenshots": "node scripts/capture-submission-screenshots.cjs"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
